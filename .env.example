# Urban Investors — site configuration template
# Copy this file to .env and fill in your real values.
# Reminder: on a static site these values are visible in the browser,
# so .env is documentation/central config, not a secret store.

# Contact / WhatsApp
WA_NUMBER=
PHONE_NUMBER=

# Lead form (Google Apps Script web app endpoint)
SCRIPT_URL=
FRONTEND_TOKEN=

# Analytics
GA_MEASUREMENT_ID=

# Hostinger FTP (real secrets — used by ./deploy.sh --ftp)
# Find these in hPanel > Files > FTP Accounts
FTP_HOST=
FTP_USER=
FTP_PASS=
FTP_PORT=21
FTP_REMOTE_DIR=/public_html
